# FastFlow Environment Variables
# Copy this file to .env and fill in your actual values

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:your_app_id

# OpenAI Configuration
VITE_OPENAI_API_KEY=your_openai_api_key_here
# Alternative: Use OpenRouter for more model options
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
VITE_STRIPE_PRO_PRICE_ID=price_your_pro_plan_price_id

# App Configuration
VITE_APP_NAME=FastFlow
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001

# Development Settings
NODE_ENV=development
VITE_DEBUG=true

# Analytics (Optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=your_posthog_key

# Feature Flags (Optional)
VITE_ENABLE_VOICE_JOURNALING=true
VITE_ENABLE_AI_COACHING=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
